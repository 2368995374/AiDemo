# 本地 AI 编码助手后端配置
# 复制本文件为 .env 并修改

APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# 模型配置
MODEL_PATH=D:\zwy\zwyAi\models\Qwen2.5-Coder-1.5B-Instruct
MODEL_DTYPE=float16
MODEL_DEVICE_MAP=auto
MODEL_OFFLINE=true
DEFAULT_SYSTEM_PROMPT=You are Qwen, a helpful coding assistant running fully offline.
DEFAULT_MAX_NEW_TOKENS=256
DEFAULT_TEMPERATURE=0.2
DEFAULT_TOP_P=0.9

# RemoteSAM（多模态图像+文本）
REMOTESAM_REPO_PATH=../RemoteSAM-master/RemoteSAM-master
REMOTESAM_CHECKPOINT=D:/zwy/zwyAi/models/RemoteSAMv1.pth
REMOTESAM_DEVICE=cuda:0
REMOTESAM_USE_EPOC=false
REMOTESAM_AUTO_LOAD=false

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=AiDemo
